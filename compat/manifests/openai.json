      "path": "/openai/v1/responses/{id}",
      "supported": true
    },
    {
      "id": "post_openai_v1_embeddings",
      "method": "POST",
      "path": "/openai/v1/embeddings",
      "supported": true
    },
    {
      "id": "post_openai_v1_files",
      "method": "POST",
      "path": "/openai/v1/files",
      "supported": true
    },
    {
      "id": "post_openai_v1_batches",
      "method": "POST",
      "path": "/openai/v1/batches",
      "supported": true
    },
    {
      "id": "get_openai_v1_batches__id",
