{
  "provider": "openai",
  "provider_version": "2025-02-01",
  "sdk": {
    "name": "openai",
    "version": "6.39.0"
  },
  "source": {
    "type": "docs",
    "title": "OpenAI Chat Completions API",
    "url_or_path": "https://platform.openai.com/docs/api-reference/chat/create",
    "retrieved_at": "2026-05-26"
  },
  "scenario": "chat_success",
  "request": {
    "method": "POST",
    "path": "/v1/chat/completions",
    "headers": {
      "Authorization": "Bearer mockport_openai_key",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-mockport",
      "messages": "bad"
    }
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "error": {
        "type": "mockport_error",
        "code": "invalid_request_error",
        "message": "messages must be an array"
      }
    }
  },
  "normalization": [
    "credentials use the mockport_ fake namespace",
    "malformed payload is a deterministic fake value",
    "error response is reduced to public documented fields"
  ]
}
