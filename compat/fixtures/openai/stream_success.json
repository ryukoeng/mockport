{
  "provider": "openai",
  "provider_version": "2025-02-01",
  "sdk": {
    "name": "openai",
    "version": "6.42.0"
  },
  "source": {
    "type": "docs",
    "title": "OpenAI Chat Completions streaming",
    "url_or_path": "https://platform.openai.com/docs/api-reference/chat/streaming",
    "retrieved_at": "2026-06-27"
  },
  "scenario": "stream_success",
  "request": {
    "method": "POST",
    "path": "/v1/chat/completions",
    "headers": {
      "Authorization": "Bearer mockport_openai_key",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-mockport",
      "messages": [
        {
          "role": "user",
          "content": "stream"
        }
      ],
      "stream": true
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "text/event-stream"
    },
    "body": {
      "events": [
        "data: {\"id\":\"chatcmpl-mockport\",\"object\":\"chat.completion.chunk\",\"created\":1700000000,\"model\":\"gpt-mockport\",\"system_fingerprint\":\"fp_mockport\",\"choices\":[{\"index\":0,\"delta\":{\"role\":\"assistant\",\"content\":\"\"},\"finish_reason\":null}]}",
        "data: {\"id\":\"chatcmpl-mockport\",\"object\":\"chat.completion.chunk\",\"created\":1700000000,\"model\":\"gpt-mockport\",\"system_fingerprint\":\"fp_mockport\",\"choices\":[{\"index\":0,\"delta\":{\"content\":\"Mockport simulated \"},\"finish_reason\":null}]}",
        "data: {\"id\":\"chatcmpl-mockport\",\"object\":\"chat.completion.chunk\",\"created\":1700000000,\"model\":\"gpt-mockport\",\"system_fingerprint\":\"fp_mockport\",\"choices\":[{\"index\":0,\"delta\":{\"content\":\"streaming response.\"},\"finish_reason\":null}]}",
        "data: {\"id\":\"chatcmpl-mockport\",\"object\":\"chat.completion.chunk\",\"created\":1700000000,\"model\":\"gpt-mockport\",\"system_fingerprint\":\"fp_mockport\",\"choices\":[{\"index\":0,\"delta\":{},\"finish_reason\":\"stop\"}]}",
        "data: [DONE]"
      ]
    }
  },
  "normalization": [
    "credentials use the mockport_ fake namespace",
    "stream chunks contain deterministic fake content split into role, content, and finish_reason phases",
    "created timestamp and chunk IDs are fixed for reproducibility",
    "no external OpenAI API calls are made"
  ]
}
