{
  "provider": "openai",
  "provider_version": "2025-02-01",
  "sdk": {
    "name": "openai",
    "version": "6.39.0"
  },
  "source": {
    "type": "docs",
    "title": "OpenAI Chat Completions API",
    "url_or_path": "https://platform.openai.com/docs/api-reference/chat/create",
    "retrieved_at": "2026-05-26"
  },
  "scenario": "chat_success",
  "request": {
    "method": "POST",
    "path": "/v1/chat/completions",
    "headers": {
      "Authorization": "Bearer mockport_openai_key",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-mockport",
      "messages": [
        {
          "role": "user",
          "content": "hello"
        }
      ]
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "id": "openai_chat_completion_000001",
      "object": "chat.completion",
      "model": "gpt-mockport",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "Mockport response"
          }
        }
      ]
    }
  },
  "normalization": [
    "credentials use the mockport_ fake namespace",
    "model name is deterministic and local",
    "resource IDs use deterministic Mockport state IDs"
  ]
}
